{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "model": "opus",
  "includeCoAuthoredBy": false,
  "prefersReducedMotion": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["Working"]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-tree:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(pnpm tsc-check:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm exec eslint:*)",
      "Bash(pnpm eslint:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(grep:*)"
    ],
    "deny": ["AskUserQuestion"]
  }
}
