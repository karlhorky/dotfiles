{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "model": "opus",
  "includeCoAuthoredBy": false,
  "prefersReducedMotion": true,
  "axScreenReader": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["Working"]
  },
  "permissions": {
    "deny": ["AskUserQuestion"]
  }
}
